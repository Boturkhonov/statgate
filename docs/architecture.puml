@startuml
left to right direction
skinparam componentStyle rectangle

cloud "Пользователи" as users

rectangle "Kubernetes кластер" {

  component "Traffic router\n(Istio VirtualService)" as gw

  rectangle "Deployments" {
    component "Stable (v1)" as blue
    component "Canary (v2)" as green
  }

  rectangle "Мониторинг" {
    database "Prometheus" as prom
    note right of prom
      - задержка (p50, p95, p99)
      - процент успешных запросов
      - количество запросов
    end note
  }

  rectangle "Control Plane" {
    component "Rollout Controller" as gate
    note right of gate
      - Последовательная проверка гипотез
      - Логика продвижения трафика
      - Решения об откате
    end note

    database "Состояние эксперимента\n(Custom CRD)" as state
    component "K8s API Server" as k8sapi
  }

}

users --> gw : HTTP запросы
gw --> blue : 75% трафика
gw --> green : 25% трафика

blue --> prom : метрики
green --> prom : метрики

blue --> k8sapi : статус подов
green --> k8sapi : статус подов

prom --> gate : запрос метрик
k8sapi --> gate : статус развертываний
gate --> state : сохранение состояния

gate --> gw : изменение весов трафика
gate --> k8sapi : команда отката
@enduml